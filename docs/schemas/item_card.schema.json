{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MatMe07/MTR-RAG-System/schemas/item_card.schema.json",
  "title": "ItemCardV2",
  "description": "Карточка изделия версии 2: строгая шапка и динамические характеристики для хранения в PostgreSQL JSONB.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "card_id",
    "card_version",
    "lifecycle_status",
    "item_type",
    "subtype",
    "name",
    "designation",
    "codes",
    "dcd",
    "properties",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0",
      "description": "Версия JSON-контракта. Не совпадает с версией конкретной карточки."
    },
    "card_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "Постоянный идентификатор изделия. Для ещё не сохранённого запроса может быть null."
    },
    "card_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Номер версии конкретной карточки. Увеличивается при подтверждённом изменении."
    },
    "lifecycle_status": {
      "type": "string",
      "enum": [
        "draft",
        "extracted",
        "normalized",
        "expert_confirmed",
        "conflict",
        "archived"
      ],
      "description": "Общий статус карточки, не статус отдельной характеристики."
    },
    "item_type": {
      "type": "string",
      "minLength": 1,
      "description": "Базовый тип изделия: труба, отвод, переход, задвижка и т.д."
    },
    "subtype": {
      "type": [
        "string",
        "null"
      ],
      "description": "Подтип или конструктивное исполнение изделия."
    },
    "name": {
      "type": [
        "string",
        "null"
      ],
      "description": "Человекочитаемое наименование изделия."
    },
    "designation": {
      "type": [
        "string",
        "null"
      ],
      "description": "Условное обозначение изделия из паспорта, каталога или запроса."
    },
    "codes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mtr_code",
        "ksm_code"
      ],
      "properties": {
        "mtr_code": {
          "type": [
            "string",
            "null"
          ],
          "description": "Код МТР, если он известен."
        },
        "ksm_code": {
          "type": [
            "string",
            "null"
          ],
          "description": "Код КСМ, если он известен."
        }
      }
    },
    "dcd": {
      "$ref": "#/$defs/dcdContext"
    },
    "properties": {
      "type": "object",
      "description": "Изменяемый набор характеристик. Название характеристики является ключом, а значение соответствует characteristicValue.",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/characteristicValue"
      }
    },
    "sources": {
      "type": "array",
      "description": "Источники, по которым собрана карточка. Характеристики ссылаются на source_fragment.fragment_id.",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "$defs": {
    "dcdContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "collection",
        "document"
      ],
      "properties": {
        "domain": {
          "oneOf": [
            {
              "$ref": "#/$defs/dcdNode"
            },
            {
              "type": "null"
            }
          ],
          "description": "Верхняя область знаний, например газопровод."
        },
        "collection": {
          "oneOf": [
            {
              "$ref": "#/$defs/dcdNode"
            },
            {
              "type": "null"
            }
          ],
          "description": "Однородная группа внутри области, например трубопроводные детали."
        },
        "document": {
          "oneOf": [
            {
              "$ref": "#/$defs/dcdDocument"
            },
            {
              "type": "null"
            }
          ],
          "description": "Основной документ карточки. Остальные документы перечисляются в sources."
        }
      }
    },
    "dcdNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "name"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dcdDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "document_type",
        "title"
      ],
      "properties": {
        "document_id": {
          "type": "string",
          "minLength": 1
        },
        "document_type": {
          "type": "string",
          "enum": [
            "passport",
            "excel",
            "lnd",
            "catalog",
            "standard",
            "user_query",
            "other"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "characteristicValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "value_type",
        "unit",
        "status",
        "confidence",
        "source_fragment_ids"
      ],
      "properties": {
        "value": {
          "type": [
            "string",
            "number",
            "boolean",
            "array",
            "null"
          ],
          "items": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "description": "Нормализованное значение. null означает, что значение неизвестно, а не отрицательно."
        },
        "value_type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "list"
          ],
          "description": "Ожидаемый тип значения для правил и интерфейса."
        },
        "raw_value": {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ],
          "description": "Исходная запись до нормализации."
        },
        "unit": {
          "type": [
            "string",
            "null"
          ],
          "description": "Каноническая единица измерения, например mm или MPa."
        },
        "status": {
          "type": "string",
          "enum": [
            "extracted",
            "normalized",
            "inferred",
            "expert_confirmed",
            "rejected",
            "conflict",
            "unknown"
          ]
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1,
          "description": "Уверенность автоматического извлечения. Для экспертного значения может быть 1."
        },
        "source_fragment_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Идентификаторы фрагментов, подтверждающих значение."
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "type",
        "document_id",
        "file_name",
        "source_fragment"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "passport",
            "excel",
            "lnd",
            "catalog",
            "standard",
            "user_query",
            "expert"
          ]
        },
        "document_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "file_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_fragment": {
          "oneOf": [
            {
              "$ref": "#/$defs/sourceFragment"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "sourceFragment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fragment_id",
        "text",
        "page",
        "row",
        "bbox"
      ],
      "properties": {
        "fragment_id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string"
        },
        "page": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "row": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "bbox": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {
                "type": "number"
              }
            },
            {
              "type": "null"
            }
          ],
          "description": "Координаты фрагмента на странице: x1, y1, x2, y2."
        }
      }
    }
  }
}
